{
  "expo": {
    "name": "PocketDiscount",
    "slug": "pocketdiscount",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pocketdiscount",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "nl.pocketdiscount.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PocketDiscount uses your location to find nearby stores with the best deals.",
        "NSCameraUsageDescription": "PocketDiscount uses the camera to scan your grocery receipts.",
        "NSPhotoLibraryUsageDescription": "PocketDiscount needs access to your photos to scan receipts."
      }
    },
    "android": {
      "package": "nl.pocketdiscount.app",
      "adaptiveIcon": {
        "backgroundColor": "#2E7D32",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "CAMERA"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-camera",
        {
          "cameraPermission": "PocketDiscount uses the camera to scan your grocery receipts."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2E7D32",
          "dark": {
            "backgroundColor": "#1B5E20"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
