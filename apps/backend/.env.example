# Server port (optional, default 3000)
# PORT=3000

# Public URL of this API (for product image URLs in responses). Default: http://localhost:3000
# PUBLIC_URL=http://localhost:3000

# PostgreSQL connection for stores (optional).
# Used by: npm run seed (scripts/seed-stores.ts)
# Create the database first, e.g.: createdb pocketdiscount
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pocketdiscount
